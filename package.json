{
  "name": "@scpxl/nodejs-framework",
  "version": "1.0.56",
  "description": "Opinionated TypeScript framework combining Fastify, WebSockets, Redis, BullMQ, and MikroORM with unified lifecycle management",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PXLbros/pxl-nodejs-framework.git"
  },
  "homepage": "https://github.com/PXLbros/pxl-nodejs-framework#readme",
  "bugs": {
    "url": "https://github.com/PXLbros/pxl-nodejs-framework/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pxl": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./application": {
      "import": "./dist/application/index.js",
      "types": "./dist/application/index.d.ts"
    },
    "./logger": {
      "import": "./dist/logger/index.js",
      "types": "./dist/logger/index.d.ts"
    },
    "./database": {
      "import": "./dist/database/index.js",
      "types": "./dist/database/index.d.ts"
    },
    "./error": {
      "import": "./dist/error/index.js",
      "types": "./dist/error/index.d.ts"
    },
    "./webserver": {
      "import": "./dist/webserver/index.js",
      "types": "./dist/webserver/index.d.ts"
    },
    "./websocket": {
      "import": "./dist/websocket/index.js",
      "types": "./dist/websocket/index.d.ts"
    },
    "./queue": {
      "import": "./dist/queue/index.js",
      "types": "./dist/queue/index.d.ts"
    },
    "./redis": {
      "import": "./dist/redis/index.js",
      "types": "./dist/redis/index.d.ts"
    },
    "./request-context": {
      "import": "./dist/request-context/index.js",
      "types": "./dist/request-context/index.d.ts"
    },
    "./cache": {
      "import": "./dist/cache/index.js",
      "types": "./dist/cache/index.d.ts"
    },
    "./performance": {
      "import": "./dist/performance/index.js",
      "types": "./dist/performance/index.d.ts"
    },
    "./command": {
      "import": "./dist/command/index.js",
      "types": "./dist/command/index.d.ts"
    },
    "./auth": {
      "import": "./dist/auth/index.js",
      "types": "./dist/auth/index.d.ts"
    },
    "./api-requester": {
      "import": "./dist/api-requester/index.js",
      "types": "./dist/api-requester/index.d.ts"
    },
    "./lifecycle": {
      "import": "./dist/lifecycle/index.js",
      "types": "./dist/lifecycle/index.d.ts"
    },
    "./util": {
      "import": "./dist/util/index.js",
      "types": "./dist/util/index.d.ts"
    },
    "./services": {
      "import": "./dist/services/index.js",
      "types": "./dist/services/index.d.ts"
    },
    "./schemas": {
      "import": "./dist/schemas/index.js",
      "types": "./dist/schemas/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "node scripts/hmr-watcher-enhanced.js",
    "dev:import-map": "tsx src/index.ts",
    "clean": "del-cli dist",
    "build": "npm run clean && node esbuild.config.js",
    "build:tsc": "npm run clean && tsc",
    "build:local": "npm run clean && node esbuild.config.js && yalc push",
    "build:watch": "node esbuild.config.js --watch",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release": "node scripts/release.js",
    "status": "node scripts/framework-status.js",
    "prepare": "husky",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e",
    "test:ui": "vitest --ui",
    "check-all": "npm run lint && npm run typecheck",
    "load:test": "tsx scripts/simple-load-test.ts",
    "load:test:hello-world": "tsx scripts/simple-load-test.ts --hello-world",
    "yalc:publish": "yalc publish",
    "yalc:push": "yalc push",
    "dev:yalc": "npm run build && npm run yalc:push",
    "example": "node scripts/run-example.js",
    "example:hello-world": "concurrently --kill-others-on-fail \"npm run example -- hello-world/backend\" \"npm run example -- hello-world/frontend\""
  },
  "keywords": [
    "nodejs",
    "framework",
    "typescript",
    "fastify",
    "websocket",
    "redis",
    "bullmq",
    "queue",
    "mikro-orm",
    "postgresql",
    "api",
    "microservice",
    "application-framework"
  ],
  "author": "SC/PXL <devops@studiocity.com>",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@swc/core": "^1.15.21",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "concurrently": "^9.2.1",
    "del-cli": "^7.0.0",
    "esbuild": "^0.27.4",
    "fast-folder-size": "^2.4.0",
    "husky": "^9.1.7",
    "ignore": "^7.0.5",
    "redis-memory-server": "^0.16.0",
    "simple-git": "^3.33.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.2",
    "yalc": "1.0.0-pre.53"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@mikro-orm/cli": "^7.0.6",
    "@mikro-orm/core": "^7.0.6",
    "@mikro-orm/migrations": "^7.0.6",
    "@mikro-orm/postgresql": "^7.0.6",
    "@mikro-orm/seeder": "^7.0.6",
    "@sentry/node": "^10.46.0",
    "@sentry/profiling-node": "^10.46.0",
    "bullmq": "^5.71.1",
    "fastify": "^5.8.4",
    "fastify-type-provider-zod": "^6.1.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "lru-cache": "^11.2.7",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,js,json}": [
      "biome check --fix --no-errors-on-unmatched"
    ]
  }
}
